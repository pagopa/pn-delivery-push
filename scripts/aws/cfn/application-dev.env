PN_DELIVERYPUSH_PAGOPANOTIFICATIONBASECOST=100
#Enable additional languages feature
PN_DELIVERYPUSH_ADDITIONALLANGSENABLED=true
#logging level for parameter store
LOGGING_LEVEL_IT_PAGOPA_PN_COMMONS_ABSTRACTIONS_IMPL=TRACE
PN_DELIVERYPUSH_NOTIFICATIONREWORKENABLED=true
PN_DELIVERYPUSH_RESTARTATTEMPTENABLED=true